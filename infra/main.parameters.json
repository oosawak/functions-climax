{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "principalId": {
      "value": "${AZURE_PRINCIPAL_ID}"
    },
    "vnetEnabled": {
      "value": "${VNET_ENABLED}"
    },

    "chronicleStorage": {
      "value": "${CHRONICLE_STORAGE}"
    },
    "chronicleFilePath": {
      "value": "${CHRONICLE_FILE_PATH}"
    },

    "languageEndpoint": {
      "value": "${LANGUAGE_ENDPOINT}"
    },
    "languageKey": {
      "value": "${LANGUAGE_KEY}"
    },
    "languageProject": {
      "value": "${LANGUAGE_PROJECT}"
    },
    "languageDeployment": {
      "value": "${LANGUAGE_DEPLOYMENT}"
    }
  }
}
